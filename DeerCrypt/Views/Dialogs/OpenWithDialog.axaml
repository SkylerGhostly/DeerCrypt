<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DeerCrypt.Views.Dialogs.OpenWithDialog"
        Background="{DynamicResource MainBackgroundBrush}"
        Title="Open With"
        Width="360"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="24" Spacing="16">

        <TextBlock x:Name="FileNameText"
                   TextWrapping="Wrap"
                   FontSize="13"
                   FontWeight="SemiBold" />

        <TextBlock Text="Choose how to open this file:"
                   Opacity="0.6"
                   FontSize="12" />

        <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,8,Auto">

            <Button Grid.Column="0" Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="0,10"
                    Click="OnMediaPlayerClicked">
                <StackPanel Spacing="4">
                    <TextBlock Text="🎵" FontSize="18" HorizontalAlignment="Center" />
                    <TextBlock Text="Media Player" FontSize="12" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="0,10"
                    Click="OnImageViewerClicked">
                <StackPanel Spacing="4">
                    <TextBlock Text="🖼" FontSize="18" HorizontalAlignment="Center" />
                    <TextBlock Text="Image Viewer" FontSize="12" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="0" Grid.Row="2"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="0,10"
                    Click="OnTextEditorClicked">
                <StackPanel Spacing="4">
                    <TextBlock Text="📄" FontSize="18" HorizontalAlignment="Center" />
                    <TextBlock Text="Text Editor" FontSize="12" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Grid.Row="2"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="0,10"
                    Click="OnExternalClicked">
                <StackPanel Spacing="4">
                    <TextBlock Text="↗" FontSize="20" HorizontalAlignment="Center" />
                    <TextBlock Text="Open Externally" FontSize="12" HorizontalAlignment="Center" />
                </StackPanel>
            </Button>

        </Grid>

        <Button HorizontalAlignment="Right"
                Margin="0,4,0,0"
                Click="OnCancelClicked"
                Content="Cancel" />

    </StackPanel>
</Window>
