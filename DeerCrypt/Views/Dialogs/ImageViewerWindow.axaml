<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DeerCrypt.ViewModels.Dialogs"
        xmlns:gif="using:Avalonia.Labs.Gif"
        xmlns:local="using:DeerCrypt.Views.Dialogs"
        x:Class="DeerCrypt.Views.Dialogs.ImageViewerWindow"
        x:DataType="vm:ImageViewerViewModel"
        Background="{DynamicResource MainBackgroundBrush}"
        Title="{Binding Title}"
        RequestedThemeVariant="Dark"
        Width="960" Height="700"
        MinWidth="420" MinHeight="320">

    <Window.Styles>

        <!-- Navigation / action buttons -->
        <Style Selector="Button.viewer">
            <Setter Property="Background"                    Value="Transparent" />
            <Setter Property="BorderThickness"               Value="0" />
            <Setter Property="Padding"                       Value="6,4" />
            <Setter Property="VerticalContentAlignment"      Value="Center" />
            <Setter Property="HorizontalContentAlignment"    Value="Center" />
            <Setter Property="FontSize"                      Value="16" />
            <Setter Property="CornerRadius"                  Value="4" />
        </Style>
        <Style Selector="Button.viewer:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.25" />
        </Style>

        <!-- Delete button - red accent on hover -->
        <Style Selector="Button.danger">
            <Setter Property="Background"                 Value="Transparent" />
            <Setter Property="BorderThickness"            Value="0" />
            <Setter Property="Padding"                    Value="6,4" />
            <Setter Property="Foreground"                 Value="#C0403A" />
            <Setter Property="FontSize"                   Value="15" />
            <Setter Property="CornerRadius"               Value="4" />
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#40CC3333" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto">

        <!--  Image display area  -->
        <Panel Grid.Row="0" Background="#090909">

            <!-- Loading indicator -->
            <TextBlock Text="Loading…"
                       IsVisible="{Binding IsLoading}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#666666"
                       FontSize="15" />

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorText}"
                       IsVisible="{Binding ErrorText,
                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="#CC5555"
                       FontSize="13"
                       TextWrapping="Wrap"
                       MaxWidth="420"
                       TextAlignment="Center" />

            <!--
                ScrollViewer + Grid combo:
                  • Grid is sized to max(imageSize, viewport) so the image is always
                    centred when smaller than the viewport.
                  • Code-behind sets Grid.Width/Height and Image/GifImage Width/Height.
            -->
            <local:ZoomScrollViewer x:Name="Scroll"
                                    HorizontalScrollBarVisibility="Auto"
                                    VerticalScrollBarVisibility="Auto"
                                    IsVisible="{Binding HasContent}">
                <!--
                    Container is sized in code-behind to max(scaledImageSize, viewport)
                    so the image is centred when smaller and scrollable when larger.
                    Stretch="Fill" with explicit Width/Height scales the image to exactly
                    the desired display size.
                -->
                <Grid x:Name="Container" Cursor="Hand" Background="Transparent">

                    <!-- Static image (JPEG, PNG, BMP, WebP, …) -->
                    <!-- IsHitTestVisible="False": makes Container the hit-test target,
                         matching the GIF path. ScrollViewer only auto-scrolls when the
                         wheel event bubbles from a nested descendant; when the source is
                         the direct content child (Container) it does not scroll, which
                         prevents the one-frame jitter on wheel-zoom. -->
                    <Image x:Name="Img"
                           Source="{Binding Bitmap}"
                           Stretch="Fill"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding !IsAnimated}"
                           IsHitTestVisible="False"
                           RenderOptions.BitmapInterpolationMode="MediumQuality" />

                    <!-- Animated GIF - Source is set from code-behind to avoid passing
                         null to GifImage.Source, which throws ArgumentException.
                         IsHitTestVisible="False" lets pointer events fall through to
                         the Container Grid so panning/zoom work the same as on images. -->
                    <gif:GifImage x:Name="AnimImg"
                                  Stretch="Fill"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding IsAnimated}"
                                  IsHitTestVisible="False" />

                </Grid>
            </local:ZoomScrollViewer>

        </Panel>

        <!--  Control bar  -->
        <Border Grid.Row="1"
                Background="#1A1A1A"
                BorderBrush="#2C2C2C"
                BorderThickness="0,1,0,0"
                Padding="10,7,10,9">

            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

                <!-- ← Previous -->
                <Button Grid.Column="0"
                        Classes="viewer"
                        Command="{Binding PreviousCommand}"
                        Width="36" Height="32"
                        FontSize="17"
                        Content="←"
                        ToolTip.Tip="Previous image (←)" />

                <!-- → Next -->
                <Button Grid.Column="1"
                        Classes="viewer"
                        Command="{Binding NextCommand}"
                        Width="36" Height="32"
                        FontSize="17"
                        Margin="2,0,0,0"
                        Content="→"
                        ToolTip.Tip="Next image (→)" />

                <!-- Counter -->
                <TextBlock Grid.Column="2"
                           Text="{Binding CountText}"
                           Foreground="#777777"
                           FontSize="12"
                           FontFamily="Consolas,monospace"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />

                <!-- Fit to window -->
                <Button Grid.Column="3"
                        x:Name="FitBtn"
                        Classes="viewer"
                        Width="34" Height="30"
                        FontSize="14"
                        Margin="0,0,6,0"
                        ToolTip.Tip="Fit to window">
                    <PathIcon Data="M3,3 h10 v10 h-10 Z M4,4 v8 h8 v-8 Z" 
                      Width="14" Height="14" 
                      Foreground="#E0E0E0" />
                </Button>

                <!-- Zoom out -->
                <Button Grid.Column="4"
                        x:Name="ZoomOutBtn"
                        Classes="viewer"
                        Width="26" Height="26"
                        FontSize="14"
                        Padding="0"
                        Content="−"
                        ToolTip.Tip="Zoom out" />

                <!-- Zoom slider (logarithmic: 0 = 5%, ~59 = 100%, 100 = 800%) -->
                <Slider Grid.Column="5"
                        x:Name="ZoomSlider"
                        Classes="zoom"
                        Minimum="0" Maximum="100"
                        Value="{Binding ZoomSliderValue, Mode=TwoWay}"
                        Width="130"
                        VerticalAlignment="Center"
                        Margin="4,0"
                        ToolTip.Tip="Zoom (scroll wheel to zoom)" />

                <!-- Zoom in -->
                <Button Grid.Column="6"
                        x:Name="ZoomInBtn"
                        Classes="viewer"
                        Width="26" Height="26"
                        FontSize="14"
                        Padding="0"
                        Content="+"
                        ToolTip.Tip="Zoom in" />

                <!-- Zoom % label -->
                <TextBlock Grid.Column="7"
                           Text="{Binding ZoomPercent}"
                           Width="48"
                           Foreground="#888888"
                           FontSize="11"
                           FontFamily="Consolas,monospace"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="4,0,12,0" />

                <!-- Delete -->
                <Button Grid.Column="9"
                        Classes="danger"
                        Command="{Binding DeleteCommand}"
                        Width="34" Height="30"
                        Content="🗑"
                        ToolTip.Tip="Delete from vault (Del)" />

            </Grid>
        </Border>

    </Grid>
</Window>
