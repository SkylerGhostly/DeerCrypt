<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DeerCrypt.ViewModels.Dialogs"
        x:Class="DeerCrypt.Views.Dialogs.OpenVaultDialog"
        x:DataType="vm:OpenVaultViewModel"
        Background="{DynamicResource MainBackgroundBrush}"
        Title="Open Vault"
        Width="460"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel>

        <!-- Header -->
        <StackPanel Margin="28,24,28,18" Spacing="4" HorizontalAlignment="Center">
            <TextBlock Text="🔐"
                       FontSize="36"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Open Vault"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0" />
            <TextBlock Text="Select your vault file and enter its password."
                       FontSize="12"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Opacity="0.45"
                       MaxWidth="320" />
        </StackPanel>

        <!-- Separator -->
        <Rectangle Height="1" Fill="#18808080" />

        <!-- Body -->
        <StackPanel Margin="28,20,28,24" Spacing="4">

            <!-- Vault Location -->
            <TextBlock Text="VAULT FILE"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Opacity="0.45"
                       LetterSpacing="1"
                       Margin="0,0,0,6" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Watermark="Path to vault file…"
                         Text="{Binding VaultPath}"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1"
                        Content="Browse…"
                        Command="{Binding BrowseCommand}"
                        Padding="12,6" />
            </Grid>

            <!-- Password -->
            <TextBlock Text="PASSWORD"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Opacity="0.45"
                       LetterSpacing="1"
                       Margin="0,14,0,6" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0"
                         Watermark="Password"
                         PasswordChar="●"
                         Text="{Binding Password}"
                         IsVisible="{Binding !ShowPassword}"
                         Margin="0,0,8,0" />
                <TextBox Grid.Column="0"
                         Watermark="Password"
                         Text="{Binding Password}"
                         IsVisible="{Binding ShowPassword}"
                         Margin="0,0,8,0" />
                <ToggleButton Grid.Column="1"
                              IsChecked="{Binding ShowPassword}"
                              Content="👁"
                              Width="36"
                              Height="32"
                              Padding="0"
                              FontSize="15"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center"
                              ToolTip.Tip="Show / hide password" />
            </Grid>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#E05252"
                       FontSize="12"
                       Margin="0,8,0,0"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       TextWrapping="Wrap" />

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,16,0,0">
                <Button Content="Cancel"
                        Click="OnCancelClicked"
                        Padding="14,6" />
                <Button Content="Open Vault"
                        Command="{Binding OpenCommand}"
                        Classes="accent"
                        IsDefault="True"
                        Padding="14,6" />
            </StackPanel>

        </StackPanel>
    </StackPanel>
</Window>
